            <defs>
              <linearGradient id="lgrad" x1="0%" y1="0%" x2="100%" y2="0%">
                <stop offset="0%" stop-color="#1e6fff"/>
                <stop offset="100%" stop-color="#00c2ff"/>
              </linearGradient>
              <pattern id="hexbg" x="0" y="0" width="36" height="41.5" patternUnits="userSpaceOnUse">
                <polygon points="18,1 34,10 34,28 18,37 2,28 2,10" fill="none" stroke="rgba(200,80,255,0.08)" stroke-width="0.7"/>
              </pattern>
              <radialGradient id="cglow" cx="50%" cy="70%" r="50%">
                <stop offset="0%"   stop-color="rgba(30,111,255,0.22)"/>
                <stop offset="100%" stop-color="transparent"/>
              </radialGradient>
              <filter id="fg" x="-40%" y="-40%" width="180%" height="180%">
                <feGaussianBlur stdDeviation="3.5" result="b"/><feMerge><feMergeNode in="b"/><feMergeNode in="SourceGraphic"/></feMerge>
              </filter>
            </defs>
            <!-- Hex grid -->
            <rect width="420" height="540" fill="url(#hexbg)" opacity="0.9"/>
            <!-- Center radial glow behind circle -->
            <ellipse cx="210" cy="390" rx="195" ry="175" fill="url(#cglow)"/>
            <!-- Neural net — left -->
            <circle cx="22" cy="200" r="4.5" fill="none" stroke="#00c2ff" stroke-width="1.2" filter="url(#fg)"><animate attributeName="r" values="4.5;6.5;4.5" dur="3s" repeatCount="indefinite"/></circle>
            <circle cx="22" cy="255" r="4"   fill="none" stroke="#1e6fff" stroke-width="1"><animate attributeName="r" values="4;6;4" dur="2.7s" repeatCount="indefinite"/></circle>
            <circle cx="22" cy="310" r="4.5" fill="none" stroke="#7c3aed" stroke-width="1"><animate attributeName="r" values="4.5;6.5;4.5" dur="3.6s" repeatCount="indefinite"/></circle>
            <circle cx="62" cy="225" r="4"   fill="none" stroke="#00c2ff" stroke-width="1"><animate attributeName="r" values="4;6;4" dur="2.4s" repeatCount="indefinite"/></circle>
            <circle cx="62" cy="280" r="3.5" fill="none" stroke="#1e6fff" stroke-width="1"><animate attributeName="r" values="3.5;5.5;3.5" dur="3.1s" repeatCount="indefinite"/></circle>
            <circle cx="96" cy="250" r="5"   fill="rgba(0,194,255,0.12)" stroke="#00c2ff" stroke-width="1.2" filter="url(#fg)"><animate attributeName="r" values="5;7.5;5" dur="4s" repeatCount="indefinite"/></circle>
            <line x1="22" y1="200" x2="62" y2="225" stroke="rgba(0,194,255,0.32)"  stroke-width="0.8"/>
            <line x1="22" y1="255" x2="62" y2="225" stroke="rgba(30,111,255,0.32)" stroke-width="0.8"/>
            <line x1="22" y1="255" x2="62" y2="280" stroke="rgba(30,111,255,0.28)" stroke-width="0.7"/>
            <line x1="22" y1="310" x2="62" y2="280" stroke="rgba(124,58,237,0.32)" stroke-width="0.8"/>
            <line x1="62" y1="225" x2="96" y2="250" stroke="rgba(0,194,255,0.4)"   stroke-width="0.9"/>
            <line x1="62" y1="280" x2="96" y2="250" stroke="rgba(30,111,255,0.4)"  stroke-width="0.9"/>
            <!-- Data pulses -->
            <circle r="2.5" fill="#00c2ff" filter="url(#fg)"><animateMotion dur="2.1s" repeatCount="indefinite" path="M22,200 L62,225 L96,250"/></circle>
            <circle r="2"   fill="#7c3aed" filter="url(#fg)"><animateMotion dur="3s"   repeatCount="indefinite" path="M22,310 L62,280 L96,250"/></circle>
            <!-- Circuit traces — bottom -->
